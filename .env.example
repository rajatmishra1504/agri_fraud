# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agri_fraud_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# AWS S3 Configuration (optional - will use local storage if not provided)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=agri-fraud-certificates

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Fraud Detection Thresholds
WEIGHT_CHANGE_THRESHOLD=15
MIN_TRAVEL_SPEED_KMH=40
MAX_TRAVEL_SPEED_KMH=120
FRAUD_SCAN_CRON=0 2 * * *

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Buyer order duplicate-submit guard (seconds)
ORDER_DUPLICATE_WINDOW_SECONDS=15

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
